import { mediaManager } from 'wix-media-backend';
import wixData from 'wix-data';

export async function assignImagesFromMediaManager() {
    const fileResult = await mediaManager.listFiles(null, null, { limit: 200 });
    const files = fileResult.files || fileResult;

    console.log(`Found ${files.length} files in Media Manager`);
    console.log("All original filenames:", files.map(f => f.originalFileName));

    return "Logged filenames, check console";
}